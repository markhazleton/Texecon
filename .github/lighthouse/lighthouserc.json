{
  "ci": {
    "collect": {
      "staticDistDir": "./lighthouse-target",
      "url": ["/", "/texecon/mark-hazleton", "/texas"],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.57 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.78 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "button-name": ["error", { "minScore": 1 }],
        "is-crawlable": ["error", { "minScore": 1 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 2800 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 5000 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.6 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 750 }],
        "unused-javascript": "off",
        "network-dependency-tree-insight": "off",
        "render-blocking-insight": "off",
        "render-blocking-resources": "off",
        "modern-image-formats": "off",
        "image-delivery-insight": "off",
        "uses-responsive-images": "off",
        "legacy-javascript": "off",
        "cls-culprits-insight": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
